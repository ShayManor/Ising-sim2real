# Hyperparam overrides for the fast_repro profile, sourced by train_ising.sbatch.
# Consumed by third_party/Ising-Decoding's training loop as env vars (see TRAINING.md
# "Training overrides"); anything left unset falls back to the vendored pipeline's
# own internal defaults.

GPUS=1

# Left unset deliberately: PREDECODER_TRAIN_EPOCHS (default 100),
# PREDECODER_TRAIN_SAMPLES (pipeline's own per-GPU default), PREDECODER_LR_MILESTONES.
# Single-GPU throughput on this cluster is unmeasured -- don't guess a sample count
# that might blow the 12h wall. Override here for a real ablation run, e.g.:
#   PREDECODER_TRAIN_EPOCHS=20
#   PREDECODER_TRAIN_SAMPLES=4194304
